# PostgreSQL (e.g. Neon, Supabase) — required for Prisma
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=""

# Production site URL (Vercel deployment URL)
AUTH_URL="http://localhost:3000"

# Resend — https://resend.com (optional; emails skipped if unset)
RESEND_API_KEY=""
EMAIL_FROM="Welfare <onboarding@resend.dev>"

# OpenAI — AI report summaries and writing assistance (optional; falls back to plain text)
OPENAI_API_KEY=""
